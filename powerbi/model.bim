            "sourceColumn": "Day of Week",
            "lineageTag": "c-dd-dow",
            "summarizeBy": "none"
          },
          {
            "name": "Day Name",
            "dataType": "string",
            "sourceColumn": "Day Name",
            "sortByColumn": "Day of Week",
            "lineageTag": "c-dd-dname",
            "summarizeBy": "none"
          },
          {
            "name": "Week Number",
            "dataType": "int64",
            "sourceColumn": "Week Number",
            "lineageTag": "c-dd-wnum",
            "summarizeBy": "none"
          },
          {
            "name": "Is Weekend",
            "dataType": "boolean",
            "sourceColumn": "Is Weekend",
            "lineageTag": "c-dd-iswe",
            "summarizeBy": "none"
          },
          {
            "name": "Is Current Month",
            "dataType": "boolean",
            "sourceColumn": "Is Current Month",
            "lineageTag": "c-dd-iscm",
            "summarizeBy": "none"
          },
          {
            "name": "Month-Year Sort",
            "dataType": "int64",
            "isHidden": true,
            "sourceColumn": "Month-Year Sort",
            "lineageTag": "c-dd-mysort",
            "summarizeBy": "none"
          },
          {
            "name": "Relative Day",
            "dataType": "int64",
            "sourceColumn": "Relative Day",
            "lineageTag": "c-dd-relday",
            "summarizeBy": "none"
          }
        ],
        "partitions": [
          {
            "name": "dim_Date",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": [
                "VAR _minDate = MIN(job_offers[scraped_at])",
                "VAR _maxDate = MAX(job_offers[scraped_at])",
                "VAR _startDate = DATE(YEAR(_minDate), MONTH(_minDate), 1)",
                "VAR _endDate = EOMONTH(_maxDate, 1)",
                "VAR _dates = CALENDAR(_startDate, _endDate)",
                "RETURN",
                "    ADDCOLUMNS(",
                "        _dates,",
                "        \"Year\",             YEAR([Date]),",
                "        \"Month Number\",     MONTH([Date]),",
                "        \"Month Name\",       FORMAT([Date], \"MMMM\", \"pl-PL\"),",
                "        \"Month Short\",      FORMAT([Date], \"MMM\", \"pl-PL\"),",
                "        \"Year-Month\",       FORMAT([Date], \"YYYY-MM\"),",
                "        \"Quarter\",          \"Q\" & FORMAT([Date], \"Q\"),",
                "        \"Year-Quarter\",     FORMAT([Date], \"YYYY\") & \"-Q\" & FORMAT([Date], \"Q\"),",
                "        \"Day of Week\",      WEEKDAY([Date], 2),",
                "        \"Day Name\",         FORMAT([Date], \"dddd\", \"pl-PL\"),",
                "        \"Week Number\",      WEEKNUM([Date], 2),",
                "        \"Is Weekend\",       IF(WEEKDAY([Date], 2) >= 6, TRUE(), FALSE()),",
                "        \"Is Current Month\", IF(",
                "            YEAR([Date]) = YEAR(TODAY()) && MONTH([Date]) = MONTH(TODAY()),",
                "            TRUE(), FALSE()",
                "        ),",
                "        \"Month-Year Sort\",  YEAR([Date]) * 100 + MONTH([Date]),",
                "        \"Relative Day\",     DATEDIFF([Date], TODAY(), DAY) * -1",
                "    )"
              ]
            }
          }
        ],
        "hierarchies": [
          {
            "name": "Date Hierarchy",
            "lineageTag": "h-date",
            "levels": [
              {
                "name": "Year",
                "ordinal": 0,
                "column": "Year",
                "lineageTag": "hl-year"
              },
              {
                "name": "Quarter",
